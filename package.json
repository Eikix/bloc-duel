{
  "name": "bloc-duel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "cards:optimize": "node scripts/optimize-card-art.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "agent:build": "esbuild src/agent/cli.ts --bundle --packages=external --platform=node --format=esm --outfile=dist-agent/cli.js",
    "agent:check": "tsc -p tsconfig.agent.json",
    "agent:cli": "npm run agent:build --silent && node --no-warnings dist-agent/cli.js",
    "agent:local": "./scripts/agent-local.sh",
    "agent:games": "npm run agent:local -- games list",
    "agent:selfplay": "npm run agent:local -- game selfplay --json",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@cartridge/connector": "^0.13.9",
    "@cartridge/controller": "^0.13.9",
    "@dojoengine/core": "^1.8.8",
    "@dojoengine/sdk": "^1.9.0",
    "@dojoengine/torii-client": "^1.8.2",
    "@react-three/drei": "^9.121.4",
    "@react-three/fiber": "^8.18.0",
    "@starknet-io/get-starknet-core": "^4.0.8",
    "@starknet-react/chains": "^5.0.1",
    "@starknet-react/core": "^5.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "fastnoise-lite": "^1.1.1",
    "framer-motion": "^12.35.0",
    "postprocessing": "^6.38.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "starknet": "^8.5.2",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "three-custom-shader-material": "^6.3.1",
    "three-mesh-bvh": "^0.9.9",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
