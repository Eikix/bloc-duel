pub fn get_cards_for_age(age: u8) -> Span<u8> {
    match age {
        1 => [0_u8, 1_u8, 2_u8, 3_u8, 4_u8, 5_u8, 6_u8, 7_u8, 8_u8, 9_u8].span(),
        2 => [10_u8, 11_u8, 12_u8, 13_u8, 14_u8, 15_u8, 16_u8, 17_u8, 18_u8, 19_u8].span(),
        3 => [20_u8, 21_u8, 22_u8, 23_u8, 24_u8, 25_u8, 26_u8, 27_u8, 28_u8, 29_u8].span(),
        _ => panic!("invalid age"),
    }
}

